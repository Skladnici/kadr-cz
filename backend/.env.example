# Copy to .env and fill in real values. See config.py for how each one is
# read/defaulted, and README.md ("Proměnné prostředí") for the full
# explanation of each variable's effect.

# Required — without these, all /api/* routes return 503 (access is
# deliberately disabled, not left open).
SITE_USERNAME=
SITE_PASSWORD=

# Production only — comma-separated list of allowed frontend origins.
# Left unset, only the local Vite dev server (localhost:5173) is allowed.
CORS_ORIGINS=

# OCR engine — leave both unset to fall back to local Tesseract (free, no
# signup, slower). Setting either switches OCR_MODE automatically; see
# config.py for the exact priority.
GOOGLE_VISION_API_KEY=
OCR_SPACE_API_KEY=

# Shared companies list (/api/companies) — without these it returns 503.
SUPABASE_URL=
SUPABASE_KEY=

# Optional overrides
OCR_MODE_OVERRIDE=
LOG_LEVEL=INFO
